{
  "name": "aidrelay",
  "version": "0.1.0",
  "description": "AI Developer Relay — Centralized MCP server config and AI rules manager",
  "private": true,
  "author": {
    "name": "Christian Blank",
    "email": "aidrelay@proton.me"
  },
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "prepare": "husky || true",
    "postinstall": "pnpm rebuild better-sqlite3 keytar",
    "predev": "node scripts/rebuild-native.mjs",
    "dev": "electron-vite dev",
    "prebuild": "node scripts/rebuild-native.mjs",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist": "pnpm build && electron-builder --config electron-builder.yml",
    "dist:win": "pnpm build && electron-builder --win --config electron-builder.yml",
    "dist:publish": "pnpm build && electron-builder --win --publish always --config electron-builder.yml",
    "typecheck": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.shared.json",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,json,css}\"",
    "pretest": "pnpm rebuild better-sqlite3 keytar",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@hookform/resolvers": "^5.2.2",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-router": "^1.166.2",
    "@tanstack/react-table": "^8.21.3",
    "@uiw/react-markdown-preview": "^5.1.5",
    "@uiw/react-md-editor": "^4.0.11",
    "better-sqlite3": "^12.6.2",
    "chokidar": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-log": "^5.2.4",
    "electron-updater": "^6.3.9",
    "i18next": "^25.8.14",
    "isomorphic-git": "^1.37.2",
    "keytar": "^7.9.0",
    "lucide-react": "^0.577.0",
    "radix-ui": "^1.4.3",
    "react-hook-form": "^7.71.2",
    "react-i18next": "^16.5.6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-ts": "^3.0.0",
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.0.12",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.13.10",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^3.1.0",
    "eslint": "^9.22.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jsdom": "^26.0.0",
    "lint-staged": "^15.4.3",
    "prettier": "^3.5.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwindcss": "^4.0.12",
    "typescript": "^5.8.2",
    "vite": "^6.2.1",
    "vitest": "^3.0.9"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,json,css}": "prettier --write",
    "src/**/*.{ts,tsx,js}": "pnpm exec eslint --fix"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "electron",
      "esbuild",
      "keytar"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
